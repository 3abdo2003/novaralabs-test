{
    "buildCommand": "npm run build",
    "outputDirectory": "dist",
    "rewrites": [
        { "source": "/api/admin/(.*)", "destination": "/api/admin-router.js" },
        { "source": "/verify/(.*)", "destination": "/index.html" },
        { "source": "/api/(.*)", "destination": "/api/$1" },
        { "source": "/(.*)", "destination": "/index.html" }
    ]
}